    "format-icons": [
      "´Çª",
      "´Çº",
      "´Ç¿ ",
    ],
    "format-muted": "¯╗¿ ",
    "tooltip-format": "{node_name}: {volume}%",
    "on-click": "kitty pulsemixer",
    "max-volume": 100,
    "scroll-step": 5
  },

  "clock": {
    "format": "{:%H:%M %d/%m}",
    "tooltip-format": "{:%A, %d %B}"
  },

  "network": {
    "interval": 5,
    "format": "{icon}",
    "on-click": "kitty nmtui",
    "format-disconnected": "¾░▓£ E",
    "format-ethernet": "¾░▓Ø E",
    "format-wifi": "{icon}",
    "format-icons": ["¾░ñ» W", "¾░ñƒ W", "¾░ñó W", "¾░ñÑ W", "¾░ñ¿ W"],
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
