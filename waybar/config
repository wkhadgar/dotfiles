{
  "layer": "top",
  "position": "top",
  "spacing": 10,

  "modules-left": ["custom/nerv", "mpris", ],
  "modules-center": ["hyprland/workspaces",],
  "modules-right": ["tray", "custom/div", "wireplumber", "network", "bluetooth", "clock", "custom/updates", "group/group-power",],

  "custom/nerv": {
    "format": " NERV ",
    "tooltip": false,
  },

  "custom/div" : {
    "format": "|",
  },

