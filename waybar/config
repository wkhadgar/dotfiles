      "<span color='#b71c1c'>ˇ░Ü░</span>"  // 20. Bord├┤ (Situa├ž├úo Cr├ştica)
    ],
    "interval": 3600,
    "on-click": "kitty -e ~/.config/waybar/scripts/update_system.sh; ~/.config/hypr/scripts/refresh_waybar.sh",
    "hide-empty-text": true,
  },

  "hyprland/window": {
    "format": "{title}",
    "tooltip-format": "{title}",
    "icon": true,
    "separate-outputs": true,
    "icon-size": 20,
    "max-length": 50,
  },

  "hyprland/workspaces": {
    "format": " [{id}] {windows} ",
    "format-window-separator": " ",
    "window-rewrite-default": "´üÖ",
    "window-rewrite": {
      "discord": "´ç┐ ",
      "title<Ôť│ (.*)>": "´üę",
      "title<.*nvim.*>": "ţá║",
      "chrome": "´ëĘ",
      "(.*) ÔÇö Mozilla Firefox":"ˇ░ł╣",
      "title<.*github.*>": "´äô",
      "kitty": "ţ×Ľ",
      "clion": "ˇ░ČŐˇ░Čôˇ░ČÉˇ░Čľˇ░ČĽ",
      "Microsoft Teams": "ˇ░Ő╗",
      "Telegram": "ţłŚ",
      "Dolphin": "ţżü",
      "Chromium-browser": "ˇ▒ľĹ",
      "Spotify": "´ć╝",
      "steam": "´ćÂ",
    },
  },

  "mpris": {
    "format": " {player_icon}  {dynamic} ",
    "format-paused": " {status_icon}  <i>{dynamic}</i> ",
    "dynamic-separator": " ţśí ",
    "dynamic-order": [
      "title", 
      "album",
      "artist", 
    ],
    "title-len": 30,
    "album-len": 30,
    "artist-len": 30,
    "player-icons": {
      "default": "ˇ░ÉÄ",
      "mpv": "­čÄÁ",
      "chromium": "´ëĘ",
      "spotify": "´ć╝",
    },
    "status-icons": {
      "paused": "´üő"
    },
  },

  "wireplumber": {
    "format": "{icon}",
    "format-icons": [
      "´ÇŽ",
      "´Çž",
      "´ÇĘ ",
    ],
    "format-muted": "ţ╗Ę ",
    "tooltip-format": "{node_name}: {volume}%",
    "on-click": "kitty pulsemixer",
    "max-volume": 100,
    "scroll-step": 5
  },

  "clock": {
    "format": "{:%H:%M %d/%m}",
    "tooltip-format": "{:%A, %d %B}"
  },

  "network": {
    "interval": 5,
    "format": "{icon}",
    "on-click": "kitty nmtui",
    "format-disconnected": "ˇ░▓ť E",
    "format-ethernet": "ˇ░▓Ł E",
    "format-wifi": "{icon}",
    "format-icons": ["ˇ░Ą» W", "ˇ░Ąč W", "ˇ░Ąó W", "ˇ░Ąą W", "ˇ░ĄĘ W"],
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}: {bandwidthDownBytes}",
    "tooltip-format-disconnected": "Disconnected",
  },

  "bluetooth": {
    "on-click": "kitty bluetui",
    "format": "ˇ░é»",
    "format-disabled": "ˇ░é▓",
    "format-connected": "ˇ░é░",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
  },

  "tray": {
    "show-passive-items": true,
    "icon-size": 16,
    "spacing": 16
  },

  "group/group-power": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/power", // First element is the "group leader" and won't ever be hidden
      "custom/lock",
      "custom/reboot",
      "custom/exit",
    ]
  },


  "custom/lock": {
    "format": "ˇ░Źü",
    "tooltip": false,
    "on-click": "hyprlock"
  },

  "custom/reboot": {
    "format": "ˇ░ťë",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm_action.sh 'REBOOT' && reboot"
  },

  "custom/exit": {
    "format": "ˇ░Ś╝",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm_action.sh 'EXIT' && hyprctl dispatch exit"
  },

  "custom/power": {
    "format": "´ÇĹ ",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm_action.sh 'SHUTDOWN' && shutdown now"
  },
}
