    "on-click": "~/.config/waybar/scripts/confirm_action.sh 'REBOOT' && reboot"
  },

  "custom/exit": {
    "format": "¾░ù╝",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/confirm_action.sh 'EXIT' && hyprctl dispatch exit"
  },

  "custom/power": {
    "format": "´Çæ ",
    "tooltip": false,
