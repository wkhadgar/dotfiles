      "<span color='#42a5f5'>ˇ░Ü░</span>", // 9. Azul (Alerta Baixo)
      "<span color='#fff9c4'>ˇ░Ü░</span>", // 10. Amarelo P├ílido (Aviso Preliminar)
      "<span color='#fff59d'>ˇ░Ü░</span>", // 11. Amarelo Claro (Aviso)
      "<span color='#fff176'>ˇ░Ü░</span>", // 12. Amarelo (Alerta Moderado)
      "<span color='#ffee58'>ˇ░Ü░</span>", // 13. Amarelo Intenso (Alerta Elevado)
      "<span color='#ffd54f'>ˇ░Ü░</span>", // 14. Dourado (Cuidado)
      "<span color='#ffb74d'>ˇ░Ü░</span>", // 15. Laranja Claro (Perigo Iminente)
      "<span color='#ff9800'>ˇ░Ü░</span>", // 16. Laranja (Perigo)
      "<span color='#f4511e'>ˇ░Ü░</span>", // 17. Laranja Escuro (Perigo Alto)
      "<span color='#e53935'>ˇ░Ü░</span>", // 18. Vermelho (Risco Alto)
